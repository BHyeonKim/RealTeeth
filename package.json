{
	"name": "realteeth",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.0.8",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
